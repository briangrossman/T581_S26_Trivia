# Copy this file to .env.local for local development
# All four variables are required

# Auto-injected by Vercel when you connect a Neon Postgres database
# For local dev: get this from your Neon dashboard
POSTGRES_URL="postgres://username:password@host/dbname?sslmode=require"

# Your Anthropic API key (for LLM scoring of Round 3 Prompt Writing questions)
ANTHROPIC_API_KEY="sk-ant-..."

# Secret used to sign teacher session tokens (use a long random string)
JWT_SECRET="generate-a-32-char-random-string-here"

# Password for the pre-seeded teacher account (username is always "teacher")
TEACHER_PASSWORD="your-chosen-password"
